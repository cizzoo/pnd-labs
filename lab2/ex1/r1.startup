# sysctl -w net.ipv6.conf.all.disable_ipv6=0
# sysctl -w net.ipv6.conf.default.disable_ipv6=0

# Assign addresses to the two LAN interfaces
ip -6 addr add 2001:db8:cafe:1::1/64 dev eth0
ip -6 addr add 2001:db8:cafe:2::1/64 dev eth1

# ip -6 route add 2001:db8:cafe:1::/64 via 2001:db8:cafe:2::1
# ip -6 route add 2001:db8:cafe:2::/64 via 2001:db8:cafe:1::1

ip link set eth0 up
ip link set eth1 up

